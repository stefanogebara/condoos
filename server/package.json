{
  "name": "condo-management-server",
  "version": "1.0.0",
  "description": "Server for condominium management system",
  "main": "dist/server.js",
  "scripts": {
    "start": "cross-env PORT=3001 ts-node src/server.ts",
    "dev": "cross-env PORT=3001 nodemon --ignore client/ src/server.ts",
    "build": "tsc",
    "migrate": "node dist/db/migrate.js"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^4.13.11",
    "@types/nodemailer": "^6.4.14",
    "@types/uuid": "^9.0.8",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "nodemailer": "^6.9.12",
    "pg": "^8.11.3",
    "svix": "^1.21.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.28",
    "@types/pg": "^8.11.2",
    "cross-env": "^7.0.3",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.2"
  },
  "nodemonConfig": {
    "ignore": [
      "client/*"
    ],
    "delay": "2500"
  }
}
