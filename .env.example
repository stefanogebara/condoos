# CondoOS — copy to .env and fill in

# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-in-prod
CORS_ORIGIN=http://localhost:3000
# Set only on disposable demo deployments. Leave unset in real production.
DEMO_AUTH_ENABLED=
# Auth limiter: per IP+email cap plus broad per-IP cap, both per 15 minutes.
AUTH_RATE_LIMIT_MAX=5
AUTH_IP_RATE_LIMIT_MAX=60

# Database (SQLite)
DB_PATH=./data/condoos.sqlite

# AI — OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku
OPENROUTER_TIMEOUT_MS=20000

# Error monitoring (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0

# Google sign-in (optional — leave empty to hide the Google button)
# 1. Create OAuth client ID at https://console.cloud.google.com/apis/credentials
# 2. Authorized JS origins: http://localhost:3000, https://condoos-ten.vercel.app
# 3. Paste the client ID below (same value on both server + Vercel env)
GOOGLE_CLIENT_ID=
# Optional: also set VITE_GOOGLE_CLIENT_ID in client-app/.env for Vercel builds

# Client analytics (optional)
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
# Exposes internal prototype pages (/design, /logos) in production builds.
VITE_EXPOSE_INTERNAL_PAGES=

# Invite email delivery (optional). When configured, board admins can email
# roster-import invites through Resend.
APP_ORIGIN=http://localhost:3000
EMAIL_PROVIDER=resend
EMAIL_FROM="CondoOS <noreply@example.com>"
RESEND_API_KEY=

# WhatsApp notifications (optional). Default provider is auto-detected.
# Twilio is official but business-initiated messages require approved templates.
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# WAHA is an unofficial WhatsApp Web bridge. Use only with a dedicated session/account.
# WHATSAPP_PROVIDER=waha
# WAHA_URL=https://your-waha-app.fly.dev/api
# WAHA_SESSION=default
# WAHA_API_KEY=

# Production E2E against Vercel Deployment Protection.
# Store the real value in your shell or CI secrets, never in git.
VERCEL_AUTOMATION_BYPASS_SECRET=
# Backward-compatible aliases accepted by playwright.config.ts:
# VERCEL_PROTECTION_BYPASS=
# VERCEL_BYPASS_SECRET=
