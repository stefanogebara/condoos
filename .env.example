# CondoOS — copy to .env and fill in

# Server
PORT=4000
NODE_ENV=development
JWT_SECRET=change-me-in-prod
CORS_ORIGIN=http://localhost:3000

# Database (SQLite)
DB_PATH=./data/condoos.sqlite

# AI — OpenRouter (https://openrouter.ai)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Google sign-in (optional — leave empty to hide the Google button)
# 1. Create OAuth client ID at https://console.cloud.google.com/apis/credentials
# 2. Authorized JS origins: http://localhost:3000, https://condoos-ten.vercel.app
# 3. Paste the client ID below (same value on both server + Vercel env)
GOOGLE_CLIENT_ID=
# Optional: also set VITE_GOOGLE_CLIENT_ID in client-app/.env for Vercel builds

# Invite email delivery (optional). When configured, board admins can email
# roster-import invites through Resend.
APP_ORIGIN=http://localhost:3000
EMAIL_PROVIDER=resend
EMAIL_FROM="CondoOS <noreply@example.com>"
RESEND_API_KEY=
